{
  "name": "open-gym-app",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "description": "Piattaforma open source di esercizi da palestra: schede di allenamento, tracking dei pesi e voti della community. PWA solo frontend, dati in localStorage.",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p cypress/tsconfig.json && tsc --noEmit -p worker/tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "NODE_OPTIONS=\"--no-experimental-webstorage\" vitest run",
    "test:unit": "NODE_OPTIONS=\"--no-experimental-webstorage\" vitest run tests/unit",
    "test:integration": "NODE_OPTIONS=\"--no-experimental-webstorage\" vitest run tests/integration",
    "test:watch": "NODE_OPTIONS=\"--no-experimental-webstorage\" vitest",
    "test:coverage": "NODE_OPTIONS=\"--no-experimental-webstorage\" vitest run --coverage",
    "test:bdd": "NODE_OPTIONS=\"--import tsx\" cucumber-js",
    "pretest:e2e": "npm run build",
    "test:e2e": "start-server-and-test 'npm run preview' http://localhost:4173 'cypress run'",
    "test:e2e:open": "start-server-and-test 'npm run dev' http://localhost:5173 'cypress open'",
    "test:all": "npm run lint && npm run format:check && npm run test && npm run test:bdd && npm run test:e2e"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "lz-string": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260712.1",
    "@cucumber/cucumber": "^13.0.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chai": "^4.3.20",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "chai": "^4.5.0",
    "cypress": "^15.18.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "start-server-and-test": "^3.0.11",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
